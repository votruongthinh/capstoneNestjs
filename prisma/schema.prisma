generator client {
  provider     = "prisma-client"
  output       = "../src/modules-system/prisma/generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "mysql"
}

model binh_luan {
  binh_luan_id   Int        @id @default(autoincrement())
  nguoi_dung_id  Int
  hinh_id        Int
  ngay_binh_luan DateTime   @db.Date
  noi_dung       String     @db.VarChar(500)
  deletedBy      Int        @default(0)
  isDeleted      Boolean    @default(false)
  deletedAt      DateTime?  @db.Timestamp(0)
  createdAt      DateTime   @default(now()) @db.Timestamp(0)
  updatedAt      DateTime   @default(now()) @db.Timestamp(0)
  hinh_anh       hinh_anh   @relation(fields: [hinh_id], references: [hinh_anh_id], onDelete: NoAction, onUpdate: NoAction, map: "fk_binhluan_hinhanh")
  nguoi_dung     nguoi_dung @relation(fields: [nguoi_dung_id], references: [nguoi_dung_id], onDelete: NoAction, onUpdate: NoAction, map: "fk_binhluan_nguoidung")

  @@index([hinh_id], map: "fk_binhluan_hinhanh")
  @@index([nguoi_dung_id], map: "fk_binhluan_nguoidung")
}

model hinh_anh {
  hinh_anh_id   Int         @id @default(autoincrement())
  ten_hinh      String      @db.VarChar(255)
  duong_dan     String      @db.VarChar(500)
  mo_ta         String      @db.VarChar(500)
  tuoi          Int?
  nguoi_dung_id Int
  deletedBy     Int         @default(0)
  isDeleted     Boolean     @default(false)
  deletedAt     DateTime?   @db.Timestamp(0)
  createdAt     DateTime    @default(now()) @db.Timestamp(0)
  updatedAt     DateTime    @default(now()) @db.Timestamp(0)
  binh_luan     binh_luan[]
  nguoi_dung    nguoi_dung  @relation(fields: [nguoi_dung_id], references: [nguoi_dung_id], onDelete: NoAction, onUpdate: NoAction, map: "fk_hinh_nguoidung")
  luu_anh       luu_anh[]

  @@index([nguoi_dung_id], map: "fk_hinh_nguoidung")
}

model luu_anh {
  nguoi_dung_id Int
  hinh_id       Int
  ngay_luu      DateTime   @db.Date
  deletedBy     Int        @default(0)
  isDeleted     Boolean    @default(false)
  deletedAt     DateTime?  @db.Timestamp(0)
  createdAt     DateTime   @default(now()) @db.Timestamp(0)
  updatedAt     DateTime   @default(now()) @db.Timestamp(0)
  hinh_anh      hinh_anh   @relation(fields: [hinh_id], references: [hinh_anh_id], onDelete: NoAction, onUpdate: NoAction, map: "fk_luuanh_hinhanh")
  nguoi_dung    nguoi_dung @relation(fields: [nguoi_dung_id], references: [nguoi_dung_id], onDelete: NoAction, onUpdate: NoAction, map: "fk_luuanh_nguoidung")

  @@id([nguoi_dung_id, hinh_id])
  @@index([hinh_id], map: "fk_luuanh_hinhanh")
}

model nguoi_dung {
  nguoi_dung_id Int         @id @default(autoincrement())
  email         String      @unique(map: "email") @db.VarChar(255)
  mat_khau      String      @db.VarChar(255)
  ho_ten        String      @db.VarChar(255)
  tuoi          Int?
  anh_dai_dien  String?     @db.VarChar(255)
  deletedBy     Int         @default(0)
  isDeleted     Boolean     @default(false)
  deletedAt     DateTime?   @db.Timestamp(0)
  createdAt     DateTime    @default(now()) @db.Timestamp(0)
  updatedAt     DateTime    @default(now()) @db.Timestamp(0)
  binh_luan     binh_luan[]
  hinh_anh      hinh_anh[]
  luu_anh       luu_anh[]
}
